# =============================================================================
# Microcord Configuration
# =============================================================================
# Copy this file to .env and customise before running the container.
# All values below are defaults — uncomment and change what you want!
# These work for both `docker compose up` (dev) and `docker compose -f
# docker-compose.prod.yml up` (prod).
# =============================================================================

# ----- Authentication --------------------------------------------------------
AUTH_PROVIDER=local
# JWT_SECRET=                     # ≥32 chars; auto-generated when blank
# ACCESS_TOKEN_EXPIRY_MINUTES=5       # Short-lived JWT access token lifetime
# REFRESH_TOKEN_EXPIRY_DAYS=30        # Long-lived refresh token lifetime
# REGISTRATION_PASSPHRASE=        # Upper-case phrase for registration; random when blank

# ----- Network ----------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173   # Dev default; set to origin URL in prod
# TRUST_PROXY=false                  # Set true if host behind a reverse proxy
# TRUSTED_PROXY_HOPS=1               # Number of trusted proxy hops for IP extraction
# INSECURE_HTTP=false                # Set true for HTTP-only (no TLS, dev purposes)

# ----- UI consts -------------------------
# APP_NAME=🔊 Microcord
# VOICE_CHANNEL_NAME=Voice channel

# ----- Live media (voice + screenshare) --------
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
# VOICE_ECHO_CANCELLATION=true
# VOICE_NOISE_SUPPRESSION=true
# VOICE_AUTO_GAIN_CONTROL=true
# VOICE_OPUS_BITRATE=32000             # 6000 to 510000 bps
# VOICE_OPUS_STEREO=false
# SCREENSHARE_WIDTH=1920
# SCREENSHARE_HEIGHT=1080
# SCREENSHARE_FRAME_RATE=60

# ----- Media processing ---------------
# MEDIA_AVIF_CRF=45
# MEDIA_AV1_CRF=55
# MEDIA_VIDEO_SCALE=0.5                # e.g. 0.5 to halve dimensions
# MEDIA_VIDEO_MAX_BITRATE=0.7M         # e.g. 0.7M
# MEDIA_FFMPEG_THREADS=2               # set to 1 if hosting on potato servers
# MEDIA_IMAGE_MAX_DIMENSION=1920
# FFMPEG_MEMORY_LIMIT_MB=3000
# CONTAINER_MEM_LIMIT=3500m            # docker container max mem allowed

# ----- Uploads ----------------------------------------------------------------
# MAX_UPLOAD_SIZE_MB=50

# ----- TLS (production) ------------------------------------
# SSL_CERTFILE=/certs/fullchain.pem
# SSL_KEYFILE=/certs/privkey.pem
# SSL_CERT_DIR=/path/to/certs/on/host
